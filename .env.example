# No API keys required for local operation.
# Copy this to .env and adjust if needed.

# OpenSearch (default matches docker-compose.yml)
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=Pharma@2024!
OPENSEARCH_INDEX=faers_reports

# Local model (Docker Model Runner)
LOCAL_MODEL_URL=http://localhost:12434/v1
# Qwen3.5-9B: used for BOTH report writing (thinking=off) and investigation (thinking=on)
# Pull with: docker model pull ai/qwen3.5:9B-UD-Q4_K_XL  (5.6 GB)
LOCAL_MODEL_NAME=docker.io/ai/qwen3.5:9B-UD-Q4_K_XL
INVESTIGATOR_MODEL=docker.io/ai/qwen3.5:9B-UD-Q4_K_XL

# Google AI Studio (optional — upgrades investigator to a cloud LLM)
# Get a free key at https://aistudio.google.com
# On 500/503/429 errors the pipeline falls back to local Qwen automatically.
# GOOGLE_API_KEY=your-key-here

# Stratified PRR — Mantel-Haenszel confounder (default: reporter_type)
# Values: reporter_type | age | sex | "" (empty = disable stratification)
STRATIFY_PRR=reporter_type

# openFDA API key (optional — raises rate limit and reaction cap for benchmarking)
# Register free at https://open.fda.gov/apis/authentication/
# OPENFDA_API_KEY=your-key-here

# Phoenix observability (optional — only used if you enable the observability profile)
# Enable: docker compose --profile observability up -d && uv sync --extra observability
PHOENIX_URL=http://localhost:6006
